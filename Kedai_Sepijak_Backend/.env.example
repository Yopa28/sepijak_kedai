# ============================================
# Environment Variables Configuration
# Kedai Sepijak Backend
# ============================================

# Server Configuration
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=kedai_sepijak

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# API Configuration
API_VERSION=v1
API_PREFIX=/api

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Logging
LOG_LEVEL=debug
LOG_FILE_PATH=./logs

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=Kedai Sepijak <noreply@kedaisepijak.com>

# Admin Configuration
ADMIN_EMAIL=admin@kedaisepijak.com
ADMIN_PASSWORD=changethispassword

# Application Settings
APP_NAME=Kedai Sepijak API
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# ============================================
# Instructions:
# 1. Copy this file to .env
# 2. Update all values with your actual configuration
# 3. Never commit .env file to version control
# ============================================
